{
  "comment": "Used by Vercel's @vercel/node when building the api/ edge function. Keeps our extensionless ESM imports valid (bundler resolution) and provides Node globals.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["api/**/*.ts", "apps/api/src/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "apps/api/src/server.ts",
    "apps/api/src/db/migrate.ts"
  ]
}
