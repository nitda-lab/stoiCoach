# Copy to apps/api/.env and fill in. NEVER commit the real .env.

# Neon Postgres connection string (https://neon.tech)
DATABASE_URL=

# Clerk backend secret key (https://dashboard.clerk.com) — starts with sk_
CLERK_SECRET_KEY=

# nanoGPT (OpenAI-compatible). Key starts with sk-nano-
NANOGPT_API_KEY=
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1
NANOGPT_MODEL=openai/gpt-oss-120b

# CORS origin of the web app
WEB_ORIGIN=http://localhost:5173
PORT=8787
